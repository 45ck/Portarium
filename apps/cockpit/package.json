    "geist": "^1.7.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.477.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-resizable-panels": "^4.6.4",
