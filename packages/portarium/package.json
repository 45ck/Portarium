{
  "name": "@portarium/openclaw-plugin",
  "version": "0.1.0",
  "type": "module",
  "description": "Native OpenClaw plugin that routes all tool calls through Portarium governance",
  "license": "MIT",
  "author": "Calvin Kennedy <calvin@calvinkennedy.com>",
  "keywords": [
    "openclaw",
    "ai-governance",
    "agent-safety",
    "approval-workflows",
    "human-in-the-loop",
    "portarium"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/45ck/Portarium.git",
    "directory": "packages/portarium"
  },
  "homepage": "https://github.com/45ck/Portarium#readme",
  "bugs": {
    "url": "https://github.com/45ck/Portarium/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.49",
    "typescript": "*"
  },
  "peerDependencies": {
    "@sinclair/typebox": ">=0.33.0",
    "openclaw": ">=2026.3.24-beta.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  }
}
